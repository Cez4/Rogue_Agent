[ext_resource type="Script" uid="uid://b2xbwfbvabqli" path="res://Scripts/ai/tasks/bt_chase_combat_target.gd" id="8_chase"]
[ext_resource type="Script" path="res://Scripts/ai/tasks/bt_low_stamina_tactical.gd" id="9_low_stamina_tactical"]

[sub_resource type="BTAction" id="BTAction_pull_attack"]
script = ExtResource("1_pull")

[sub_resource type="BTCondition" id="BTCondition_validate_attack"]
script = ExtResource("2_validate")

[sub_resource type="BTCondition" id="BTCondition_perception_attack"]
script = ExtResource("3_perception")

[sub_resource type="BTCondition" id="BTCondition_inrange_attack"]
script = ExtResource("4_inrange")

[sub_resource type="BTAction" id="BTAction_face_attack"]
script = ExtResource("5_face")

[sub_resource type="BTAction" id="BTAction_wait_stamina_attack"]
script = ExtResource("6_wait_stamina")
min_wait_ms = 140

[sub_resource type="BTAction" id="BTAction_request_attack"]
script = ExtResource("7_attack")

[sub_resource type="BTSequence" id="BTSequence_attack"]
custom_name = "Combat Attack"
children = [SubResource("BTAction_pull_attack"), SubResource("BTCondition_validate_attack"), SubResource("BTCondition_perception_attack"), SubResource("BTCondition_inrange_attack"), SubResource("BTAction_face_attack"), SubResource("BTAction_wait_stamina_attack"), SubResource("BTAction_request_attack")]

[sub_resource type="BTCooldown" id="BTCooldown_attack_gate"]
duration = 0.12
children = [SubResource("BTSequence_attack")]

[sub_resource type="BTAction" id="BTAction_pull_chase"]
script = ExtResource("1_pull")

[sub_resource type="BTCondition" id="BTCondition_validate_chase"]
script = ExtResource("2_validate")

[sub_resource type="BTCondition" id="BTCondition_perception_chase"]
script = ExtResource("3_perception")

[sub_resource type="BTAction" id="BTAction_chase"]
script = ExtResource("8_chase")

[sub_resource type="BTTimeLimit" id="BTTimeLimit_chase"]
time_limit = 1.0
children = [SubResource("BTAction_chase")]

[sub_resource type="BTSequence" id="BTSequence_chase"]
custom_name = "Combat Chase"
children = [SubResource("BTAction_pull_chase"), SubResource("BTCondition_validate_chase"), SubResource("BTCondition_perception_chase"), SubResource("BTTimeLimit_chase")]

[sub_resource type="BTAction" id="BTAction_low_stamina_tactical"]
script = ExtResource("9_low_stamina_tactical")

[sub_resource type="BTSequence" id="BTSequence_low_stamina_tactical"]
custom_name = "Low Stamina Tactical"
children = [SubResource("BTAction_pull_attack"), SubResource("BTCondition_validate_attack"), SubResource("BTCondition_perception_attack"), SubResource("BTAction_low_stamina_tactical")]

[sub_resource type="BTDynamicSelector" id="BTSelector_root"]
children = [SubResource("BTSequence_low_stamina_tactical"), SubResource("BTCooldown_attack_gate"), SubResource("BTSequence_chase")]

[resource]
root_task = SubResource("BTSelector_root")
