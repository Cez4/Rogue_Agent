[gd_resource type="BehaviorTree" format=3 uid="uid://clxtjhojbk2dw"]

[ext_resource type="Script" uid="uid://dr4lmrr6lyur3" path="res://Scripts/ai/tasks/bt_pull_combat_target.gd" id="1_pull"]
[ext_resource type="Script" uid="uid://ejey0wbvj4bq" path="res://Scripts/ai/tasks/bt_validate_combat_target_alive.gd" id="2_validate"]
[ext_resource type="Script" uid="uid://b0orfy45ioia7" path="res://Scripts/ai/tasks/bt_validate_combat_target_perception.gd" id="3_perception"]
[ext_resource type="Script" uid="uid://dbpqu4jqdacsi" path="res://Scripts/ai/tasks/bt_is_combat_target_in_attack_range.gd" id="4_inrange"]
[ext_resource type="Script" uid="uid://d0880ogn0cija" path="res://Scripts/ai/tasks/bt_face_combat_target_8dir.gd" id="5_face"]
[ext_resource type="Script" path="res://Scripts/ai/tasks/bt_wait_stamina_regen.gd" id="6_wait_stamina"]
